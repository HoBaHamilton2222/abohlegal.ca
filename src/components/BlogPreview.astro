---
/**
 * BlogPreview.astro
 *
 * Future integration: This component will fetch from the blog content collection
 * using `getCollection('blog')` and display the 3 most recent posts in a
 * 3-column grid of BlogCard components.
 *
 * For now, no blog posts exist so this component renders nothing.
 *
 * Example future usage:
 *   import { getCollection } from 'astro:content';
 *   import BlogCard from './BlogCard.astro';
 *   const posts = (await getCollection('blog'))
 *     .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
 *     .slice(0, 3);
 */

const posts: any[] = [];
---

{posts.length > 0 && (
  <section class="py-16 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold text-xs font-bold uppercase tracking-widest mb-2 text-center">Resources</p>
      <h2 class="font-heading text-navy text-2xl md:text-3xl lg:text-4xl font-bold text-center mb-12">
        Recent Legal Updates
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {/* BlogCard components will be mapped here when posts exist */}
      </div>
    </div>
  </section>
)}
