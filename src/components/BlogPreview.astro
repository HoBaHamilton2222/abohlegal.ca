---
import { getCollection } from 'astro:content';
import BlogCard from './BlogCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const posts = sorted.slice(0, 3);
---

{posts.length > 0 && (
  <section class="py-16 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold text-xs font-bold uppercase tracking-widest mb-2 text-center">Resources</p>
      <h2 class="font-heading text-navy text-2xl md:text-3xl lg:text-4xl font-bold text-center mb-12">
        Recent Legal Updates
      </h2>
      {posts.length < 3 ? (
        <div class="flex justify-center gap-8">
          {posts.map((post) => (
            <div class="w-full max-w-sm">
              <BlogCard
                title={post.data.title}
                date={post.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
                category={post.data.category}
                excerpt={post.data.excerpt}
                slug={post.id}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              date={post.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
              category={post.data.category}
              excerpt={post.data.excerpt}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </div>
  </section>
)}
