---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
const id = `faq-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="faq-item border-b border-gray-200">
  <button
    type="button"
    class="faq-toggle flex w-full items-center justify-between py-4 text-left"
    aria-expanded="false"
    aria-controls={id}
  >
    <span class="font-heading font-bold text-navy text-base md:text-lg pr-4">{question}</span>
    <svg
      class="faq-chevron h-5 w-5 flex-shrink-0 text-gold transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div
    id={id}
    class="faq-panel overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out"
  >
    <p class="text-body-text text-sm md:text-base leading-relaxed pb-4 pr-8">
      {answer}
    </p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq-toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const expanded = button.getAttribute('aria-expanded') === 'true';
        const panelId = button.getAttribute('aria-controls');
        if (!panelId) return;
        const panel = document.getElementById(panelId);
        if (!panel) return;
        const chevron = button.querySelector('.faq-chevron');

        if (expanded) {
          button.setAttribute('aria-expanded', 'false');
          panel.style.maxHeight = '0';
          if (chevron) chevron.classList.remove('rotate-180');
        } else {
          button.setAttribute('aria-expanded', 'true');
          panel.style.maxHeight = panel.scrollHeight + 'px';
          if (chevron) chevron.classList.add('rotate-180');
        }
      });
    });
  });
</script>
