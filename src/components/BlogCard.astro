---
interface Props {
  title: string;
  date: string;
  category: string;
  excerpt: string;
  slug: string;
}

const { title, date, category, excerpt, slug } = Astro.props;
---

<a href={`/resources/${slug}`} class="block border border-[#eee] rounded-lg p-6 hover:shadow-md transition-shadow duration-200">
  <span class="text-gold text-xs font-bold uppercase tracking-wider">{category}</span>
  <h3 class="text-navy font-bold text-lg mt-2 mb-2">{title}</h3>
  <p class="text-muted-text text-sm leading-relaxed mb-4">{excerpt}</p>
  <span class="text-muted-text text-sm">Read more &rarr;</span>
</a>
