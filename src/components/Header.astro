---
const currentPath = Astro.url.pathname;

const services = [
  { label: 'Family Law', href: '/services/family-law' },
  { label: 'Wills & Estates', href: '/services/wills-estates' },
  { label: 'Estate Litigation', href: '/services/estate-litigation' },
  { label: 'Employment Law', href: '/services/employment-law' },
  { label: 'Business & Commercial', href: '/services/business-commercial' },
  { label: 'Civil Litigation', href: '/services/civil-litigation' },
  { label: 'Personal Injury', href: '/services/personal-injury' },
  { label: 'Immigration', href: '/services/immigration' },
];

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '#', hasDropdown: true },
  { label: 'Resources', href: '/resources' },
  { label: 'Contact', href: '/contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function isServicesActive(): boolean {
  return currentPath.startsWith('/services');
}
---

<header class="sticky top-0 z-50 bg-navy">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/images/logo-wc.png" alt="Aboh Legal logo" class="h-11 md:h-12" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        link.hasDropdown ? (
          <div class="group relative">
            <button
              class:list={[
                'flex items-center gap-1 text-sm font-medium uppercase tracking-wider text-white transition-opacity',
                isServicesActive() ? 'opacity-100' : 'opacity-70 hover:opacity-100',
              ]}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {link.label}
              <svg class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            {isServicesActive() && (
              <span class="absolute -bottom-1 left-0 h-0.5 w-full bg-gold"></span>
            )}
            <!-- Dropdown -->
            <div class="invisible absolute left-0 top-full z-50 min-w-[220px] rounded-b-md bg-navy pt-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:opacity-100">
              {services.map((s) => (
                <a
                  href={s.href}
                  class:list={[
                    'block px-5 py-2.5 text-sm text-white transition-colors hover:bg-gold/20',
                    isActive(s.href) ? 'bg-gold/10 text-gold' : 'opacity-80 hover:opacity-100',
                  ]}
                >
                  {s.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'relative text-sm font-medium uppercase tracking-wider text-white transition-opacity',
              isActive(link.href) ? 'opacity-100' : 'opacity-70 hover:opacity-100',
            ]}
          >
            {link.label}
            {isActive(link.href) && (
              <span class="absolute -bottom-1 left-0 h-0.5 w-full bg-gold"></span>
            )}
          </a>
        )
      ))}

      <!-- CTA Button (desktop) -->
      <a
        href="/contact"
        class="ml-2 rounded bg-gold px-5 py-2 text-sm font-bold text-navy transition-colors hover:bg-gold/90"
      >
        Book a Consultation
      </a>
    </div>

    <!-- Mobile Right Side -->
    <div class="flex items-center gap-3 md:hidden">
      <!-- Phone icon -->
      <a href="tel:+18254610107" class="text-white" aria-label="Call Aboh Legal">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </a>

      <!-- CTA Button (mobile) -->
      <a
        href="/contact"
        class="rounded bg-gold px-3 py-1.5 text-xs font-bold text-navy"
      >
        Book a Consultation
      </a>

      <!-- Hamburger -->
      <button id="mobile-menu-btn" class="text-white" aria-label="Open menu" aria-expanded="false">
        <svg id="hamburger-icon" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="hidden h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="hidden border-t border-white/10 bg-navy md:hidden">
    <div class="mx-auto max-w-7xl px-4 py-4">
      {navLinks.map((link) => (
        link.hasDropdown ? (
          <div>
            <button
              class="mobile-services-toggle flex w-full items-center justify-between py-3 text-sm font-medium uppercase tracking-wider text-white opacity-80"
              aria-expanded="false"
            >
              {link.label}
              <svg class="mobile-chevron h-4 w-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="mobile-services-list hidden pl-4">
              {services.map((s) => (
                <a
                  href={s.href}
                  class="mobile-nav-link block py-2 text-sm text-white opacity-70 hover:opacity-100"
                >
                  {s.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'mobile-nav-link block py-3 text-sm font-medium uppercase tracking-wider text-white',
              isActive(link.href) ? 'opacity-100' : 'opacity-80',
            ]}
          >
            {link.label}
          </a>
        )
      ))}
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!menuBtn || !mobileMenu || !hamburgerIcon || !closeIcon) return;

    // Toggle mobile menu
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Services accordion
    const servicesToggle = mobileMenu.querySelector('.mobile-services-toggle');
    const servicesList = mobileMenu.querySelector('.mobile-services-list');
    const chevron = mobileMenu.querySelector('.mobile-chevron');

    if (servicesToggle && servicesList && chevron) {
      servicesToggle.addEventListener('click', () => {
        const isOpen = !servicesList.classList.contains('hidden');
        servicesList.classList.toggle('hidden');
        chevron.classList.toggle('rotate-180');
        servicesToggle.setAttribute('aria-expanded', String(!isOpen));
      });
    }

    // Close menu when a link is clicked
    const mobileLinks = mobileMenu.querySelectorAll('.mobile-nav-link');
    mobileLinks.forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  });
</script>
