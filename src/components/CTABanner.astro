---
interface Props {
  heading: string;
  body: string;
  buttonText: string;
  buttonHref: string;
}

const { heading, body, buttonText, buttonHref } = Astro.props;
---

<section class="bg-gradient-to-r from-gold to-[#d4aa5a] py-12 md:py-16 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="font-heading text-navy text-2xl md:text-3xl lg:text-4xl font-bold mb-4">
      {heading}
    </h2>
    <p class="text-navy text-base md:text-lg mb-8 leading-relaxed">
      {body}
    </p>
    <a
      href={buttonHref}
      class="inline-block bg-navy text-white font-bold px-8 py-3 rounded hover:bg-opacity-90 transition-colors text-sm md:text-base uppercase tracking-wider"
    >
      {buttonText}
    </a>
  </div>
</section>
