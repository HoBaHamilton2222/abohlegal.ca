---
const values = [
  {
    heading: 'Always Available',
    description: 'Responsive communication, even on short notice',
  },
  {
    heading: 'Fearless Advocacy',
    description: 'Your matter is taken seriously, regardless of size',
  },
  {
    heading: 'A Lawyer Who Listens',
    description: 'Understanding your situation before advising',
  },
];
---

<section class="bg-navy py-16 md:py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-white text-2xl md:text-3xl lg:text-4xl font-bold text-center mb-12">
      What You Can Expect
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {values.map((value, i) => (
        <div class:list={["animate-on-scroll border border-white/20 rounded-lg p-8 text-center", i === 0 ? "animate-delay-1" : i === 1 ? "animate-delay-2" : "animate-delay-3"]}>
          <div class="w-10 h-1 bg-gold mx-auto mb-5" />
          <h3 class="text-white font-bold text-lg mb-3">{value.heading}</h3>
          <p class="text-white/70 text-sm leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
