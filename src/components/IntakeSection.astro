---
import { siteConfig } from '../data/siteConfig';

const { cosmoLexUrl } = siteConfig;
---

<section class="bg-navy py-16 md:py-20 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="font-heading text-white text-2xl md:text-3xl lg:text-4xl font-bold mb-4">
      Ready to Get Started?
    </h2>
    <p class="text-gray-300 text-base md:text-lg leading-relaxed mb-8">
      If you're ready to discuss your matter in detail, complete our intake questionnaire to help us prepare for your consultation.
    </p>
    {cosmoLexUrl ? (
      <a
        href={cosmoLexUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-gold text-white font-bold px-8 py-3 rounded hover:bg-opacity-90 transition-colors text-sm md:text-base uppercase tracking-wider"
      >
        Start Intake Questionnaire
      </a>
    ) : (
      <p class="text-gray-400 text-base leading-relaxed">
        Our online intake form is coming soon. In the meantime, please use the contact form above or call us directly.
      </p>
    )}
  </div>
</section>
