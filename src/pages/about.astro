---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTABanner from '../components/CTABanner.astro';
import headshot from '../assets/headshot.jpg';
---

<BaseLayout
  title="About Prince Aboh | ABOH LEGAL"
  description="Meet Prince Aboh, a family law litigator serving Alberta from St. Paul. Trained in Nigeria, licensed in Alberta, committed to your community."
>
  <!-- Section 1: Hero -->
  <Hero
    title="Prince Aboh"
    subtitle="Barrister & Solicitor"
    backgroundImage="/images/stock/prairie-road.jpg"
  />

  <!-- Section 2: Story -->
  <section class="bg-[#f9f8f6] py-16 md:py-20 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <!-- Photo -->
      <div class="flex justify-center">
        <div class="relative inline-block">
          <img
            src={headshot.src}
            alt="Prince Aboh, Barrister and Solicitor"
            class="rounded-sm max-w-[350px] w-full object-cover aspect-[3/4] shadow-xl border border-gray-200"
            style="border-bottom: 4px solid #c9a84c;"
            width="350"
            height="467"
          />
        </div>
      </div>
      <!-- Narrative -->
      <div>
        <p class="text-gold text-xs font-bold uppercase tracking-widest mb-2">My Story</p>
        <h2 class="font-heading text-navy text-2xl md:text-3xl font-bold mb-6">
          From Lagos to St. Paul
        </h2>
        <div class="space-y-5 text-body-text text-base md:text-lg leading-relaxed">
          <p>
            Called to the Nigerian Bar in 2014, Prince began his legal career in corporate and commercial litigation in Lagos, then transitioned to in-house counsel roles across the energy, finance, and non-profit sectors. Those years built a foundation in navigating complexity and keeping client objectives at the centre of every decision.
          </p>
          <p>
            Prince immigrated to Canada in 2020 and earned his NCA Certificate of Qualification from the Federation of Law Societies of Canada. He volunteered with the Elizabeth Fry Society in Calgary, helping people navigate the courthouse system. After articling at a respected boutique litigation firm in Calgary, he was called to the Alberta Bar in 2024.
          </p>
          <p>
            St. Paul caught his attention during visits to the region. The community was welcoming, grounded, and different from the pace of Calgary in all the right ways. Prince relocated with his family in 2025 and opened ABOH LEGAL to serve the region directly, bringing the kind of thoughtful, accessible legal counsel every community deserves.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Credentials -->
  <section class="bg-white py-16 md:py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-navy text-2xl md:text-3xl lg:text-4xl font-bold text-center mb-12">
        Education & Memberships
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Education -->
        <div>
          <h3 class="font-heading text-navy text-lg md:text-xl font-bold mb-6">Education</h3>
          <ul class="space-y-4">
            <li class="border-l-4 border-gold pl-4">
              <p class="font-bold text-navy">LL.B (Hons)</p>
              <p class="text-muted-text text-sm">University of Maiduguri, 2013</p>
            </li>
            <li class="border-l-4 border-gold pl-4">
              <p class="font-bold text-navy">Nigerian Law School</p>
              <p class="text-muted-text text-sm">2014</p>
            </li>
            <li class="border-l-4 border-gold pl-4">
              <p class="font-bold text-navy">NCA Certificate of Qualification</p>
              <p class="text-muted-text text-sm">Federation of Law Societies of Canada, 2022</p>
            </li>
          </ul>
        </div>
        <!-- Professional Memberships -->
        <div>
          <h3 class="font-heading text-navy text-lg md:text-xl font-bold mb-6">Professional Memberships</h3>
          <ul class="space-y-4">
            <li class="border-l-4 border-gold pl-4">
              <p class="font-bold text-navy">Law Society of Alberta</p>
            </li>
            <li class="border-l-4 border-gold pl-4">
              <p class="font-bold text-navy">Canadian Bar Association</p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: How I Work -->
  <section class="bg-[#f9f8f6] py-16 md:py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-heading text-navy text-2xl md:text-3xl lg:text-4xl font-bold text-center mb-12">
        How I Work
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Always Available -->
        <div class="bg-white rounded-lg p-8 shadow-sm">
          <h3 class="font-heading text-navy text-lg md:text-xl font-bold mb-4">Always Available</h3>
          <p class="text-body-text leading-relaxed">
            I believe in responsive communication. When you're going through a difficult time, waiting days for a callback isn't acceptable. I make myself available, even on short notice, because your matter is urgent to you, and that makes it urgent to me.
          </p>
        </div>
        <!-- Fearless Advocacy -->
        <div class="bg-white rounded-lg p-8 shadow-sm">
          <h3 class="font-heading text-navy text-lg md:text-xl font-bold mb-4">Fearless Advocacy</h3>
          <p class="text-body-text leading-relaxed">
            Every client's matter deserves full commitment, regardless of its size or complexity. I prepare thoroughly, advocate vigorously, and never shy away from the difficult conversations or positions that serve your interests.
          </p>
        </div>
        <!-- A Lawyer Who Listens -->
        <div class="bg-white rounded-lg p-8 shadow-sm">
          <h3 class="font-heading text-navy text-lg md:text-xl font-bold mb-4">A Lawyer Who Listens</h3>
          <p class="text-body-text leading-relaxed">
            Before I can advise, I need to understand. I take the time to listen, truly listen, to what you're going through. The best legal strategy starts with understanding not just the facts, but the person behind them.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: CTA Banner -->
  <CTABanner
    heading="Ready to discuss your situation?"
    body="Book a consultation: in person, by phone, or by video."
    buttonText="Schedule a Consultation"
    buttonHref="/contact"
  />
</BaseLayout>
