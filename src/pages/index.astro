---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/TrustBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ValuesSection from '../components/ValuesSection.astro';
import BlogPreview from '../components/BlogPreview.astro';
import CTABanner from '../components/CTABanner.astro';
import { services } from '../data/services';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout
  title="ABOH LEGAL | Family Law, Estates & More | St. Paul, Alberta"
  description="Client-centred legal counsel for families, homeowners, newcomers, and small businesses across Alberta. Book a consultation with Prince Aboh."
>
  <!-- Section 1: Split Hero -->
  <section class="bg-gradient-to-br from-navy to-[#14304a] py-16 md:py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-12 items-center">
      <!-- Left column -->
      <div>
        <p class="text-gold text-xs font-bold uppercase tracking-[0.2em] mb-6">
          Barrister &amp; Solicitor &middot; St. Paul, Alberta
        </p>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          <span class="text-white">Clear advice.</span><br />
          <span class="text-white">Steady advocacy.</span><br />
          <span class="text-gold">Alberta-wide.</span>
        </h1>
        <p class="text-white/70 text-lg md:text-xl leading-relaxed mb-8 max-w-xl">
          Client-centred legal counsel for families, homeowners, newcomers, and small businesses navigating life's most important decisions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-block bg-gold text-navy font-bold px-8 py-3 rounded text-center hover:bg-[#d4aa5a] transition-colors text-sm uppercase tracking-wider"
          >
            Schedule a Consultation
          </a>
          <a
            href={siteConfig.phoneHref}
            class="inline-block border-2 border-white text-white font-bold px-8 py-3 rounded text-center hover:bg-white/10 transition-colors text-sm uppercase tracking-wider"
          >
            &#9742; {siteConfig.phone}
          </a>
        </div>
      </div>
      <!-- Right column -->
      <div class="flex justify-center lg:justify-end">
        <img
          src="/images/hero-illustration.svg"
          alt="Scales of justice and courthouse illustration"
          class="max-w-xs md:max-w-sm w-full"
          width="400"
          height="500"
        />
      </div>
    </div>
  </section>

  <!-- Section 2: Trust Bar -->
  <TrustBar />

  <!-- Section 3: Practice Areas -->
  <section class="bg-white py-16 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold text-xs font-bold uppercase tracking-widest mb-2 text-center">Practice Areas</p>
      <h2 class="font-heading text-navy text-2xl md:text-3xl lg:text-4xl font-bold text-center mb-12">
        How We Can Help
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {services.map((service) => (
          <ServiceCard name={service.name} slug={service.slug} description={service.shortDesc} />
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: About Preview -->
  <section class="bg-light-bg py-16 md:py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-gold text-xs font-bold uppercase tracking-widest mb-2">About Prince Aboh</p>
      <h2 class="font-heading text-navy text-2xl md:text-3xl lg:text-4xl font-bold mb-6">
        A litigator who listens first
      </h2>
      <p class="text-body-text text-base md:text-lg leading-relaxed mb-6 max-w-2xl mx-auto">
        Trained in Lagos. Licensed in Alberta. Rooted in St. Paul. Prince brings a global perspective and a personal touch to every file, from complex custody disputes to straightforward estate planning.
      </p>
      <a href="/about" class="text-gold font-bold hover:underline">
        Read more &rarr;
      </a>
    </div>
  </section>

  <!-- Section 5: Values -->
  <ValuesSection />

  <!-- Section 6: Blog Preview (renders nothing until posts exist) -->
  <BlogPreview />

  <!-- Section 7: CTA Banner -->
  <CTABanner
    heading="Ready to discuss your situation?"
    body="Book a consultation: in person, by phone, or by video."
    buttonText="Schedule Now"
    buttonHref="/contact"
  />
</BaseLayout>
