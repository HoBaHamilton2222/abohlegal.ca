---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import IntakeSection from '../components/IntakeSection.astro';
import GoogleMap from '../components/GoogleMap.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout
  title="Contact Us | ABOH LEGAL"
  description="Contact ABOH LEGAL in St. Paul, Alberta. Call (825) 461-0107 or send us a message. Legal Aid certificates accepted."
>
  <!-- Section 1: Hero -->
  <Hero label="Contact" title="Get in Touch" backgroundImage="/images/stock/alberta-fall.jpg" />

  <!-- Section 2: Contact Info + Form (two-column) -->
  <section class="bg-[#f9f8f6] py-16 md:py-20 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- LEFT: Contact Info Card -->
      <div class="bg-white rounded-lg p-8 shadow-sm h-fit">
        <h2 class="font-heading text-navy text-2xl font-bold mb-6">Contact Information</h2>
        <div class="space-y-6">
          <!-- Phone -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <div>
              <p class="text-navy font-bold text-sm uppercase tracking-wider mb-1">Phone</p>
              <a href={siteConfig.phoneHref} class="text-gold font-bold text-lg hover:underline">
                {siteConfig.phone}
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <div>
              <p class="text-navy font-bold text-sm uppercase tracking-wider mb-1">Email</p>
              <a href={`mailto:${siteConfig.email}`} class="text-gold font-bold text-lg hover:underline">
                {siteConfig.email}
              </a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div>
              <p class="text-navy font-bold text-sm uppercase tracking-wider mb-1">Address</p>
              <p class="text-body-text text-base leading-relaxed">{siteConfig.address.full}</p>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <p class="text-navy font-bold text-sm uppercase tracking-wider mb-1">Office Hours</p>
              <p class="text-body-text text-base leading-relaxed">{siteConfig.hours}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Contact Form -->
      <div>
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- Section 3: Intake Section -->
  <IntakeSection />

  <!-- Section 4: Google Map -->
  <GoogleMap />

  <!-- Section 5: Disclaimer -->
  <section class="py-8 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-muted-text text-sm leading-relaxed">
        Do not include confidential details in this form. Submitting an inquiry does not create a solicitor-client relationship.
      </p>
    </div>
  </section>

  <!-- Section 6: CTA Banner -->
  <CTABanner
    heading="Prefer to talk?"
    body="Call us directly at (825) 461-0107"
    buttonText="Call Now"
    buttonHref="tel:+18254610107"
  />
</BaseLayout>
