---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTABanner from '../components/CTABanner.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

interface Props {
  title: string;
  description: string;
  label: string;
  fullDesc: string;
  whatWeHandle: string[];
  approach: string;
  faqs: Array<{ question: string; answer: string }>;
  relatedServices: Array<{ name: string; slug: string; shortDesc: string }>;
  ctaText: string;
  metaTitle: string;
  heroImage?: string;
}

const {
  title,
  description,
  label,
  fullDesc,
  whatWeHandle,
  approach,
  faqs,
  relatedServices,
  ctaText,
  metaTitle,
  heroImage,
} = Astro.props;
---

<BaseLayout title={metaTitle} description={description}>
  <Hero title={title} backgroundImage={heroImage} />

  <!-- Full Description -->
  <section class="bg-white py-12 md:py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-body-text text-base md:text-lg leading-relaxed">
        {fullDesc}
      </p>
    </div>
  </section>

  <!-- What We Handle -->
  <section class="bg-light-bg py-12 md:py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-navy text-2xl md:text-3xl font-bold mb-8 text-center">
        What We Handle
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {whatWeHandle.map((item) => (
          <div class="flex items-start gap-3 bg-white rounded-md px-5 py-4 border-l-[3px] border-gold">
            <svg class="h-5 w-5 text-gold flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-navy font-medium text-sm md:text-base">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="bg-white py-12 md:py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-heading text-navy text-2xl md:text-3xl font-bold mb-6 text-center">
        Our Approach
      </h2>
      <div class="prose prose-lg max-w-none text-body-text leading-relaxed" set:html={approach} />
    </div>
  </section>

  <!-- Common Questions -->
  {faqs.length > 0 && (
    <section class="bg-light-bg py-12 md:py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-navy text-2xl md:text-3xl font-bold mb-8 text-center">
          Common Questions
        </h2>
        <div class="bg-white rounded-lg shadow-sm px-6 md:px-8">
          {faqs.map((faq) => (
            <FAQAccordion question={faq.question} answer={faq.answer} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <CTABanner
    heading="Let's Talk About Your Situation"
    body={ctaText}
    buttonText="Book a Consultation"
    buttonHref="/contact"
  />

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="bg-white py-12 md:py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-navy text-2xl md:text-3xl font-bold mb-8 text-center">
          Related Services
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {relatedServices.map((service) => (
            <ServiceCard name={service.name} slug={service.slug} description={service.shortDesc} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
